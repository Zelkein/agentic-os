{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "deepseek/deepseek-v4-flash",
  "default_agent": "jasper",
  "provider": {
    "deepseek": {
      "options": {
        "apiKey": "${DEEPSEEK_API_KEY}",
        "baseURL": "https://api.deepseek.com/v1"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash",
          "id": "deepseek-chat",
          "tool_call": true,
          "limit": { "context": 128000, "output": 8192 }
        },
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 PRO",
          "id": "deepseek-chat",
          "tool_call": true,
          "limit": { "context": 1000000, "output": 8192 }
        }
      }
    }
  },
  "permission": {
    "bash": "allow",
    "edit": {
      "*.md": "allow",
      "*.json": "allow",
      "*.ts": "allow",
      "*.tsx": "allow",
      "*.css": "allow",
      "*.cjs": "allow",
      "*.js": "allow",
      "*.env": "deny",
      "*.lock": "deny",
      "*": "ask"
    },
    "external_directory": {
      "/mnt/c/agentic-os-v2/*": "allow",
      "/mnt/p/Ai/*": "allow",
      "/home/zelkein/.config/kilo/*": "allow",
      "/*": "deny"
    }
  },
  "skills": {
    "paths": [
      "./.claude/skills",
      "./.kilo/skills"
    ]
  },
  "instructions": [
    "AGENTS.md",
    "CLAUDE.md",
    ".claude/skills/**/SKILL.md"
  ]
}
